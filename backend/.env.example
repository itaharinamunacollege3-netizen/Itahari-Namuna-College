DATABASE_URL="postgresql://postgres:password@localhost:5432/INC_college"
JWT_ACCESS_SECRET="change-me-access-secret-min-32-characters-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-characters-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=5000
NODE_ENV="development"
EXPOSE_AUTH_TOKENS_IN_BODY="true"
CORS_ORIGIN="http://localhost:5173"
COOKIE_DOMAIN="localhost"
COOKIE_SECURE="false"
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
TRUST_PROXY=1
ADMIN_EMAIL=info@namunacollege.edu.np
SEED_ADMIN_EMAIL=admin@namunacollege.edu.np
SEED_ADMIN_PASSWORD=ChangeMe@123456
# Cloudinary (required for gallery & notice uploads)
# Dashboard: https://console.cloudinary.com
# 1. Copy Cloud name, API Key, API Secret from Dashboard
# 2. Settings → Security → Access Keys → create/edit key with Upload permission enabled
#    (403 errors mean the key is missing "create"/upload permission)
CLOUDINARY_CLOUD_NAME=your-cloud-name-here
CLOUDINARY_API_KEY=your-api-key-here
CLOUDINARY_API_SECRET=your-api-secret-here
CLOUDINARY_FOLDER=inc-college/gallery
MAX_UPLOAD_SIZE_MB=10
CLOUDINARY_MAX_IMAGE_WIDTH=1920
CLOUDINARY_WEBP_QUALITY=75
