generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AdmissionProgram {
  PLUS2
  BCA
  BHM
  BSW
}

enum Plus2Stream {
  SCIENCE
  MANAGEMENT
  HUMANITIES
  EDUCATION
}

enum AdmissionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum NotificationType {
  ADMISSION_NEW
  CONTACT_NEW
  ADMISSION_STATUS
  SYSTEM
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  passwordHash        String
  name                String
  role                String    @default("admin")
  isActive            Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  passwordChangedAt   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  refreshTokens   RefreshToken[]
  passwordHistory PasswordHistory[]
  auditLogs       AuditLog[]
  notifications   Notification[]
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PasswordHistory {
  id           Int      @id @default(autoincrement())
  userId       Int
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  email     String
  ipAddress String
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  resource   String?
  resourceId Int?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Notice {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  title          String
  content        String
  summary        String?
  category       String
  tags           Json
  audience       String?
  author         String?
  attachmentUrl            String?
  attachmentType           String?
  attachmentCloudinaryId   String?
  imageUrl                 String?
  imageCloudinaryId        String?
  published      Boolean  @default(true)
  featured       Boolean  @default(false)
  showInPopup    Boolean  @default(false)
  showInMarquee  Boolean  @default(false)
  marqueeText    String?
  publishedDate  String
  publishedAt    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published, publishedDate])
  @@index([published, featured])
  @@index([category])
  @@index([slug])
}

model Program {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  title          String
  code           String
  image          String?
  duration       String?
  university     String?
  tagline        String?
  overview       String
  objectives     Json
  careerPathways Json
  eligibility    Json
  highlights     Json
  curriculum     Json
  seats          Int?
  isFeatured     Boolean  @default(true)
  sortOrder      Int      @default(0)
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model StaffCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staff       Staff[]

  @@index([slug])
}

model FacultyDepartment {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  faculty     Faculty[]

  @@index([slug])
}

model Faculty {
  id            Int               @id @default(autoincrement())
  name          String
  designation   String
  departmentId  Int
  department    FacultyDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  qualification String?
  bio           String?
  photo         String?
  isHOD         Boolean           @default(false)
  sortOrder     Int               @default(0)
  published     Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([departmentId, isHOD])
}

model Staff {
  id         Int           @id @default(autoincrement())
  name       String
  role       String
  department String?
  categoryId Int
  category   StaffCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  photo      String?
  sortOrder  Int           @default(0)
  published  Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([categoryId])
}





model GalleryAlbum {
  id                     Int            @id @default(autoincrement())
  slug                   String         @unique
  title                  String
  coverImage             String?
  coverImageCloudinaryId String?
  description            String?
  isFeatured             Boolean        @default(false)
  sortOrder              Int            @default(0)
  published              Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  images                 GalleryImage[]
}

model GalleryImage {
  id                 Int          @id @default(autoincrement())
  albumId            Int
  imageUrl           String
  cloudinaryPublicId String?
  caption            String?
  sortOrder          Int          @default(0)
  album              GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
}



model AdmissionApplication {
  id              Int              @id @default(autoincrement())
  fullName        String
  email           String
  gender          String
  phone           String
  address         String
  programApplied  AdmissionProgram
  plus2Stream     Plus2Stream?
  session         String?
  photoUrl        String?
  transcriptUrl   String?
  citizenshipUrl  String?
  accessTokenHash String
  status          AdmissionStatus  @default(PENDING)
  adminNotes      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([programApplied])
  @@index([email])
}

model ContactInquiry {
  id         Int      @id @default(autoincrement())
  fullName   String
  email      String
  phone      String?
  department String?
  subject    String?
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([isRead, createdAt])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

model Download {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  category    String
  programSlug String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
