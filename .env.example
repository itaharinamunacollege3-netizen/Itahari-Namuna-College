# Base URL of the backend API (no trailing slash).
# The notices and contact features call `${VITE_API_BASE_URL}/...`.
# Leave unset to fall back to bundled mock data.
VITE_API_BASE_URL="http://localhost:5000/api"
# Dev proxy target for Vite (no trailing slash, no /api at end)
VITE_DEV_PROXY_TARGET="http://localhost:5000"
